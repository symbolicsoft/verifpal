attacker[passive]

principal Alice [
    knows public   pubdata
    knows private  secret
    knows public   pk

    knows password pwd1
    knows password pwd2
    knows password pwd3
    knows password pwd4
    knows password pwd5
    knows password pwd6
    knows password pwd7
    knows password pwd8
    knows password pwd9
    knows password pwd10
    knows password pwd11

    m1  = ENC(pwd1, secret)
    m2  = ENC(pwd2, pubdata)
    m3  = ENC(secret, pwd3)
    m4  = MAC(pwd4, secret)
    m5  = MAC(secret, pwd5)
    m6  = MAC(pwd6, pubdata)
    m7  = AEAD_ENC(pwd7, secret, pubdata)
    m8  = AEAD_ENC(pwd8, pubdata, pubdata)
    m9  = BLIND(secret, pwd9)
    m10 = SIGN(pwd10, secret)
    m11, _, _ = SHAMIR_SPLIT(pwd11)
]

principal Bob []

Alice -> Bob: m1, m2, m3, m4, m5, m6, m7, m8, m9, m10, m11

queries [
    // Pass: pwd1 is the key of ENC(pwd1, secret). The attacker does not
    // know secret, so it cannot verify key guesses.
    confidentiality? pwd1
    // Fail: pwd2 is the key of ENC(pwd2, pubdata). The attacker knows
    // pubdata, so it computes ENC(guess, pubdata) and compares.
    confidentiality? pwd2
    // Pass: pwd3 is the plaintext of ENC(secret, pwd3). The attacker
    // does not know secret (the key), so it cannot reconstruct the ENC
    // to verify a guess.
    confidentiality? pwd3
    // Pass: pwd4 is the key of MAC(pwd4, secret). The attacker does not
    // know secret, so it cannot compute MAC(guess, secret) to verify.
    confidentiality? pwd4
    // Pass: pwd5 is the message of MAC(secret, pwd5). The attacker does
    // not know secret (the key), so it cannot verify.
    confidentiality? pwd5
    // Fail: pwd6 is the key of MAC(pwd6, pubdata). The attacker knows
    // pubdata, so it computes MAC(guess, pubdata) and compares.
    confidentiality? pwd6
    // Pass: pwd7 is the key of AEAD_ENC(pwd7, secret, pubdata). The
    // attacker does not know secret, so even though pubdata is known,
    // it cannot reconstruct the full AEAD_ENC to verify.
    confidentiality? pwd7
    // Fail: pwd8 is the key of AEAD_ENC(pwd8, pubdata, pubdata). The
    // attacker knows both siblings, so it can verify.
    confidentiality? pwd8
    // Pass: pwd9 is the blinding factor in BLIND(secret, pwd9). The
    // attacker does not know secret, so it cannot verify.
    confidentiality? pwd9
    // Pass: pwd10 is the signing key in SIGN(pwd10, secret). The
    // attacker does not know secret (the message), so it cannot
    // compute SIGN(guess, secret) to verify.
    confidentiality? pwd10
    // Fail: pwd11 is the sole argument of SHAMIR_SPLIT(pwd11). There
    // are no siblings, so verification is trivially possible: the
    // attacker computes SHAMIR_SPLIT(guess) and compares.
    confidentiality? pwd11
    // Pass: secret is private and never sent directly. None of the
    // passwords protecting it (pwd1, pwd3, pwd4, pwd5, pwd7, pwd9,
    // pwd10) are obtainable, so no decomposition path reaches secret.
    confidentiality? secret
]
