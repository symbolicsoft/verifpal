attacker[passive]

principal Alice[
	knows private key
	knows public data
	knows password pwd_1
	msg1 = ENC(key, pwd_1)
	knows password pwd_2
	msg2 = ENC(key, CONCAT(pwd_2, data))
	knows password pwd_3
	msg3 = CONCAT(ENC(key, pwd_3), data)
]

principal Bob[
	knows private key
]

Alice -> Bob: msg1, msg2, msg3

principal Bob[
	s1 = DEC(key, msg1)
	s2, d2 = SPLIT(DEC(key, msg2))
	se3, d3 = SPLIT(msg3)
	s3 = DEC(key, se3)
]

queries[
	confidentiality? pwd_1
	confidentiality? pwd_2
	confidentiality? pwd_3
]
